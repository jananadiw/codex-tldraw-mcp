{
  "name": "codex-tldraw-mcp",
  "version": "0.2.0",
  "mcpName": "io.github.jananadiw/codex-tldraw-mcp",
  "description": "A Codex stdio MCP server for generating tldraw product workflow diagrams.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "codex-tldraw-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "assets/github-project-preview-minimal-under-1mb.jpg",
    "assets/tldrawmcp.gif",
    "CHANGELOG.md",
    "dist",
    "docs/release-v0.1.1.md",
    "docs/release-v0.2.0.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "server.json",
    "package.json"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.check.json --noEmit",
    "dev": "bun src/index.ts",
    "smoke": "bun scripts/smoke.ts",
    "test": "bun run smoke",
    "prepack": "bun run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tldraw",
    "codex",
    "codex-desktop",
    "mcp-server",
    "developer-tools",
    "repo-visualization",
    "codebase-visualization",
    "architecture-diagrams",
    "workflow-diagrams",
    "codex-mcp"
  ],
  "homepage": "https://github.com/jananadiw/codex-tldraw-mcp#readme",
  "bugs": {
    "url": "https://github.com/jananadiw/codex-tldraw-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jananadiw/codex-tldraw-mcp.git"
  },
  "author": "jananadiw",
  "maintainers": [
    "jananadiw"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tldraw": "^5.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
